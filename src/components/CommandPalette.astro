---
import { getCollection } from 'astro:content';

type CommandGroup = 'Navigation' | 'Sections' | 'Blog' | 'Projects' | 'Uses' | 'Actions';

interface CommandItem {
  id: string;
  title: string;
  subtitle?: string;
  group: CommandGroup;
  url: string;
  keywords?: string[];
  external?: boolean;
  icon: string;
}

const posts = await getCollection('blog');

const projectItems: CommandItem[] = [
  {
    id: 'project-water-level',
    title: 'Water Level Monitoring',
    subtitle: 'React Native · WebSocket · IoT',
    group: 'Projects',
    url: '/projects#water-level-monitoring',
    keywords: ['react native', 'websocket', 'iot', 'mobile'],
    icon: 'folder',
  },
  {
    id: 'project-hris',
    title: 'HRIS System',
    subtitle: 'Laravel · Payroll · Attendance',
    group: 'Projects',
    url: '/projects#hris-system',
    keywords: ['laravel', 'php', 'hr', 'payroll'],
    icon: 'folder',
  },
  {
    id: 'project-ais-nelayan',
    title: 'AIS Nelayan',
    subtitle: 'Next.js · Mapbox · Vessel tracking',
    group: 'Projects',
    url: '/projects#ais-nelayan',
    keywords: ['nextjs', 'mapbox', 'geofencing', 'maritime'],
    icon: 'folder',
  },
  {
    id: 'project-freshrss',
    title: 'FreshRSS Pipeline',
    subtitle: 'Python · ChromaDB · AI summaries',
    group: 'Projects',
    url: '/projects#freshrss-pipeline',
    keywords: ['python', 'rss', 'ai', 'openai', 'telegram'],
    icon: 'folder',
  },
];

const navigationItems: CommandItem[] = [
  { id: 'nav-home', title: 'Home', group: 'Navigation', url: '/', icon: 'home' },
  { id: 'nav-projects', title: 'All Projects', group: 'Navigation', url: '/projects', icon: 'folder' },
  { id: 'nav-blog', title: 'Blog', group: 'Navigation', url: '/blog', icon: 'doc' },
  { id: 'nav-uses', title: 'Uses', subtitle: 'Tools, hardware, and software', group: 'Navigation', url: '/uses', icon: 'wrench' },
];

const sectionItems: CommandItem[] = [
  { id: 'section-about', title: 'About', group: 'Sections', url: '/#about', icon: 'user' },
  { id: 'section-projects', title: 'Featured Projects', group: 'Sections', url: '/#projects', icon: 'folder' },
  { id: 'section-blog', title: 'Latest Articles', group: 'Sections', url: '/#blog', icon: 'doc' },
  { id: 'section-contact', title: 'Contact', group: 'Sections', url: '/#contact', icon: 'mail' },
];

const blogItems: CommandItem[] = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    id: `post-${post.slug}`,
    title: post.data.title,
    subtitle: `${post.data.category}${post.data.readTime ? ' · ' + post.data.readTime : ''}`,
    group: 'Blog' as const,
    url: `/blog/${post.slug}`,
    keywords: [...post.data.tags, post.data.category, post.data.description],
    icon: 'doc',
  }));

const actionItems: CommandItem[] = [
  {
    id: 'action-github',
    title: 'GitHub Profile',
    subtitle: 'github.com/roshitx',
    group: 'Actions',
    url: 'https://github.com/roshitx',
    external: true,
    icon: 'github',
  },
  {
    id: 'action-linkedin',
    title: 'LinkedIn',
    subtitle: 'linkedin.com/in/roshit',
    group: 'Actions',
    url: 'https://linkedin.com/in/roshit',
    external: true,
    icon: 'linkedin',
  },
  {
    id: 'action-email',
    title: 'Send Email',
    subtitle: 'aulia.rasyid@arita.co.id',
    group: 'Actions',
    url: 'mailto:aulia.rasyid@arita.co.id',
    icon: 'mail',
  },
  {
    id: 'action-copy-email',
    title: 'Copy email address',
    subtitle: 'aulia.rasyid@arita.co.id',
    group: 'Actions',
    url: 'action:copy-email',
    icon: 'copy',
  },
  {
    id: 'action-scroll-top',
    title: 'Scroll to top',
    group: 'Actions',
    url: 'action:scroll-top',
    icon: 'arrow-up',
  },
];

const allCommands: CommandItem[] = [
  ...navigationItems,
  ...sectionItems,
  ...blogItems,
  ...projectItems,
  ...actionItems,
];

const commandsJson = JSON.stringify(allCommands);
---

<!-- Command palette root (hidden by default) -->
<div
  id="command-palette"
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="command-palette-title"
>
  <!-- Backdrop -->
  <div
    class="absolute inset-0 bg-primary-900/40 backdrop-blur-sm opacity-0 transition-opacity duration-200"
    data-cp-backdrop
    aria-hidden="true"
  ></div>

  <!-- Panel container (anchored from top on mobile, center-ish on desktop) -->
  <div class="relative h-full flex items-start justify-center pt-[12vh] px-4">
    <div
      class="w-full max-w-xl bg-white rounded-2xl shadow-floating border border-primary-100 overflow-hidden
             opacity-0 -translate-y-2 scale-[0.98] transition-all duration-200 ease-out"
      data-cp-panel
    >
      <h2 id="command-palette-title" class="sr-only">Command palette</h2>

      <!-- Search input -->
      <div class="flex items-center gap-3 px-4 py-3.5 border-b border-primary-100">
        <svg class="w-5 h-5 text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 110-16 8 8 0 010 16z"/>
        </svg>
        <input
          id="command-palette-input"
          type="text"
          placeholder="Search pages, posts, projects, tools…"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 bg-transparent text-primary-900 placeholder:text-primary-400
                 font-body text-base outline-none border-none"
          aria-label="Search"
          aria-controls="command-palette-results"
          aria-autocomplete="list"
        />
        <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 font-mono text-[10px] font-semibold text-primary-500 bg-primary-100 rounded border border-primary-200">
          ESC
        </kbd>
      </div>

      <!-- Results -->
      <div
        id="command-palette-results"
        class="max-h-[60vh] overflow-y-auto py-2"
        role="listbox"
        aria-label="Search results"
      ></div>

      <!-- Footer hint -->
      <div class="flex items-center justify-between px-4 py-2.5 border-t border-primary-100 bg-primary-50/60">
        <div class="flex items-center gap-3 text-[11px] text-primary-500">
          <span class="flex items-center gap-1">
            <kbd class="inline-flex items-center px-1 py-0.5 font-mono font-semibold bg-white rounded border border-primary-200">↑</kbd>
            <kbd class="inline-flex items-center px-1 py-0.5 font-mono font-semibold bg-white rounded border border-primary-200">↓</kbd>
            to navigate
          </span>
          <span class="flex items-center gap-1">
            <kbd class="inline-flex items-center px-1 py-0.5 font-mono font-semibold bg-white rounded border border-primary-200">↵</kbd>
            to select
          </span>
        </div>
        <span class="text-[11px] text-primary-400 font-medium hidden sm:block">
          Search by <span class="text-primary-600">Roshit</span>
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Command data -->
<script id="command-palette-data" type="application/json" set:html={commandsJson}></script>

<script>
  type CommandItem = {
    id: string;
    title: string;
    subtitle?: string;
    group: string;
    url: string;
    keywords?: string[];
    external?: boolean;
    icon: string;
  };

  const ICONS: Record<string, string> = {
    home: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>',
    folder: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/>',
    doc: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l2.25 2.25L15 12m-1.5-9.75H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>',
    user: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>',
    mail: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>',
    wrench: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>',
    github: '<path fill="currentColor" d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>',
    linkedin: '<path fill="currentColor" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>',
    copy: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75"/>',
    'arrow-up': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19.5v-15m0 0l-6.75 6.75M12 4.5l6.75 6.75"/>',
    external: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>',
  };

  const FILLED_ICONS = new Set(['github', 'linkedin']);
  const RECENT_KEY = 'cmdk:recent';
  const MAX_RECENT = 5;

  function iconMarkup(name: string): string {
    const path = ICONS[name] || ICONS.doc;
    const filled = FILLED_ICONS.has(name);
    return `<svg class="w-4 h-4" ${filled ? 'fill="currentColor"' : 'fill="none" stroke="currentColor"'} viewBox="0 0 24 24" aria-hidden="true">${path}</svg>`;
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  /* Tiny fuzzy matcher: returns score + matched indices */
  function fuzzyMatch(query: string, text: string): { score: number; indices: number[] } | null {
    if (!query) return { score: 0, indices: [] };
    const q = query.toLowerCase();
    const t = text.toLowerCase();

    // Exact substring → high score
    const idx = t.indexOf(q);
    if (idx !== -1) {
      const indices: number[] = [];
      for (let i = 0; i < q.length; i++) indices.push(idx + i);
      return { score: 1000 - idx - (t.length - q.length) * 0.1, indices };
    }

    // Subsequence match
    let ti = 0;
    let qi = 0;
    const indices: number[] = [];
    let score = 0;
    let prevMatched = false;
    while (ti < t.length && qi < q.length) {
      if (t[ti] === q[qi]) {
        indices.push(ti);
        score += prevMatched ? 10 : 2;
        if (ti === 0 || t[ti - 1] === ' ' || t[ti - 1] === '-' || t[ti - 1] === '/') score += 5;
        qi++;
        prevMatched = true;
      } else {
        prevMatched = false;
      }
      ti++;
    }
    if (qi < q.length) return null;
    score -= t.length * 0.05;
    return { score, indices };
  }

  function highlight(text: string, indices: number[]): string {
    if (!indices.length) return escapeHtml(text);
    const set = new Set(indices);
    let out = '';
    for (let i = 0; i < text.length; i++) {
      const ch = escapeHtml(text[i]);
      out += set.has(i) ? `<mark class="bg-transparent text-accent-600 font-semibold">${ch}</mark>` : ch;
    }
    return out;
  }

  function loadRecent(): string[] {
    try {
      const raw = localStorage.getItem(RECENT_KEY);
      return raw ? (JSON.parse(raw) as string[]) : [];
    } catch {
      return [];
    }
  }

  function saveRecent(id: string): void {
    try {
      const prev = loadRecent().filter((r) => r !== id);
      prev.unshift(id);
      localStorage.setItem(RECENT_KEY, JSON.stringify(prev.slice(0, MAX_RECENT)));
    } catch {
      /* noop */
    }
  }

  (function initCommandPalette() {
    const root = document.getElementById('command-palette');
    const dataEl = document.getElementById('command-palette-data');
    const input = document.getElementById('command-palette-input') as HTMLInputElement | null;
    const resultsEl = document.getElementById('command-palette-results');
    const backdrop = root?.querySelector<HTMLElement>('[data-cp-backdrop]');
    const panel = root?.querySelector<HTMLElement>('[data-cp-panel]');

    if (!root || !dataEl || !input || !resultsEl || !backdrop || !panel) return;

    const commands: CommandItem[] = JSON.parse(dataEl.textContent || '[]');
    const commandById = new Map<string, CommandItem>(commands.map((c) => [c.id, c]));

    let filtered: Array<{ cmd: CommandItem; indices: number[] }> = [];
    let activeIndex = 0;
    let lastFocus: HTMLElement | null = null;

    function computeFiltered(query: string) {
      if (!query.trim()) {
        const recentIds = loadRecent();
        const recents = recentIds
          .map((id) => commandById.get(id))
          .filter((c): c is CommandItem => Boolean(c))
          .map((cmd) => ({ cmd: { ...cmd, group: 'Recent' as unknown as CommandItem['group'] }, indices: [] }));
        const rest = commands.map((cmd) => ({ cmd, indices: [] as number[] }));
        return [...recents, ...rest];
      }
      const scored: Array<{ cmd: CommandItem; indices: number[]; score: number }> = [];
      for (const cmd of commands) {
        const haystack = [cmd.title, cmd.subtitle ?? '', cmd.group, ...(cmd.keywords ?? [])].join(' ');
        const m = fuzzyMatch(query, haystack);
        if (m) {
          // Re-run specifically on title so we can highlight nicely
          const titleMatch = fuzzyMatch(query, cmd.title);
          scored.push({
            cmd,
            indices: titleMatch ? titleMatch.indices : [],
            score: (titleMatch ? titleMatch.score * 2 : 0) + m.score,
          });
        }
      }
      scored.sort((a, b) => b.score - a.score);
      return scored.map(({ cmd, indices }) => ({ cmd, indices }));
    }

    function render() {
      const q = input!.value;
      filtered = computeFiltered(q);

      if (!filtered.length) {
        resultsEl!.innerHTML = `
          <div class="px-4 py-10 text-center">
            <div class="text-sm text-primary-500">No results for <span class="font-medium text-primary-800">"${escapeHtml(q)}"</span></div>
            <div class="text-xs text-primary-400 mt-1">Try a different search.</div>
          </div>`;
        return;
      }

      activeIndex = Math.min(activeIndex, filtered.length - 1);

      // Group results while preserving order
      const groupsInOrder: string[] = [];
      const grouped = new Map<string, Array<{ cmd: CommandItem; indices: number[]; flatIndex: number }>>();
      filtered.forEach((item, flatIndex) => {
        const g = item.cmd.group as string;
        if (!grouped.has(g)) {
          grouped.set(g, []);
          groupsInOrder.push(g);
        }
        grouped.get(g)!.push({ ...item, flatIndex });
      });

      const html = groupsInOrder
        .map((g) => {
          const items = grouped.get(g)!;
          const header = `<div class="px-4 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-primary-400">${escapeHtml(g)}</div>`;
          const rows = items
            .map(({ cmd, indices, flatIndex }) => {
              const isActive = flatIndex === activeIndex;
              return `
                <button
                  type="button"
                  role="option"
                  data-index="${flatIndex}"
                  data-id="${escapeHtml(cmd.id)}"
                  aria-selected="${isActive}"
                  class="cp-item w-full flex items-center gap-3 px-4 py-2.5 text-left transition-colors duration-100 ${
                    isActive ? 'bg-accent-50' : 'hover:bg-primary-50'
                  }"
                >
                  <span class="shrink-0 w-7 h-7 rounded-md flex items-center justify-center ${
                    isActive ? 'bg-accent-100 text-accent-700' : 'bg-primary-100 text-primary-600'
                  }">${iconMarkup(cmd.icon)}</span>
                  <span class="min-w-0 flex-1">
                    <span class="block text-sm font-medium text-primary-900 truncate">${
                      indices.length ? highlight(cmd.title, indices) : escapeHtml(cmd.title)
                    }</span>
                    ${
                      cmd.subtitle
                        ? `<span class="block text-xs text-primary-500 truncate">${escapeHtml(cmd.subtitle)}</span>`
                        : ''
                    }
                  </span>
                  ${cmd.external ? `<span class="shrink-0 text-primary-400">${iconMarkup('external')}</span>` : ''}
                  ${
                    isActive
                      ? '<kbd class="shrink-0 hidden sm:inline-flex items-center px-1.5 py-0.5 font-mono text-[10px] font-semibold text-accent-700 bg-white rounded border border-accent-200">↵</kbd>'
                      : ''
                  }
                </button>`;
            })
            .join('');
          return header + rows;
        })
        .join('');

      resultsEl!.innerHTML = html;
      scrollActiveIntoView();
    }

    function scrollActiveIntoView() {
      const el = resultsEl!.querySelector<HTMLElement>(`[data-index="${activeIndex}"]`);
      if (el) el.scrollIntoView({ block: 'nearest' });
    }

    function executeCommand(cmd: CommandItem) {
      saveRecent(cmd.id);
      if (cmd.url.startsWith('action:')) {
        const action = cmd.url.slice('action:'.length);
        if (action === 'copy-email') {
          const email = cmd.subtitle || 'aulia.rasyid@arita.co.id';
          navigator.clipboard?.writeText(email).catch(() => {});
        } else if (action === 'scroll-top') {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        close();
        return;
      }
      if (cmd.external) {
        window.open(cmd.url, '_blank', 'noopener,noreferrer');
        close();
        return;
      }
      close();
      // Slight delay lets the closing animation finish before navigation
      setTimeout(() => {
        window.location.href = cmd.url;
      }, 80);
    }

    function open() {
      if (!root!.classList.contains('hidden')) return;
      lastFocus = document.activeElement as HTMLElement | null;
      root!.classList.remove('hidden');
      // Force reflow to enable transitions
      void backdrop!.offsetHeight;
      backdrop!.classList.add('opacity-100');
      panel!.classList.remove('opacity-0', '-translate-y-2', 'scale-[0.98]');
      panel!.classList.add('opacity-100', 'translate-y-0', 'scale-100');
      document.body.style.overflow = 'hidden';
      input!.value = '';
      activeIndex = 0;
      render();
      requestAnimationFrame(() => input!.focus());
    }

    function close() {
      backdrop!.classList.remove('opacity-100');
      panel!.classList.add('opacity-0', '-translate-y-2', 'scale-[0.98]');
      panel!.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
      document.body.style.overflow = '';
      setTimeout(() => {
        root!.classList.add('hidden');
        lastFocus?.focus();
      }, 180);
    }

    // Triggers
    document.addEventListener('keydown', (e) => {
      const isMod = e.metaKey || e.ctrlKey;
      if (isMod && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (root!.classList.contains('hidden')) open();
        else close();
        return;
      }
      if (e.key === '/' && document.activeElement === document.body) {
        e.preventDefault();
        open();
        return;
      }
      if (root!.classList.contains('hidden')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIndex = Math.min(activeIndex + 1, filtered.length - 1);
        render();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIndex = Math.max(activeIndex - 1, 0);
        render();
      } else if (e.key === 'Home') {
        e.preventDefault();
        activeIndex = 0;
        render();
      } else if (e.key === 'End') {
        e.preventDefault();
        activeIndex = Math.max(filtered.length - 1, 0);
        render();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const item = filtered[activeIndex];
        if (item) executeCommand(item.cmd);
      }
    });

    input.addEventListener('input', () => {
      activeIndex = 0;
      render();
    });

    resultsEl.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.cp-item');
      if (!btn) return;
      const idx = Number(btn.dataset.index);
      const item = filtered[idx];
      if (item) executeCommand(item.cmd);
    });

    resultsEl.addEventListener('mousemove', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.cp-item');
      if (!btn) return;
      const idx = Number(btn.dataset.index);
      if (!Number.isNaN(idx) && idx !== activeIndex) {
        activeIndex = idx;
        render();
      }
    });

    backdrop.addEventListener('click', close);

    // Any button with [data-open-command-palette] triggers it
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-open-command-palette]');
      if (btn) {
        e.preventDefault();
        open();
      }
    });

    // Expose a global in case future code wants to open it
    (window as unknown as { openCommandPalette?: () => void }).openCommandPalette = open;
  })();
</script>
