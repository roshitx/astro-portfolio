---
// Hero Section Component
// Features: Animated entrance, scroll indicator, social links
---

<section 
  id="hero" 
  class="relative min-h-screen flex items-center justify-center pt-20 md:pt-24 overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 -left-32 w-64 h-64 bg-accent-100/50 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl"></div>
  </div>

  <div class="container-custom relative">
    <div class="max-w-3xl mx-auto text-center">
      
      <!-- Availability Badge -->
      <div 
        class="inline-flex items-center gap-2 px-4 py-2 bg-success-50 border border-success-100 
               rounded-full mb-6 md:mb-8 opacity-0 animate-fade-in-up"
        style="animation-fill-mode: forwards;"
      >
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-success-500"></span>
        </span>
        <span class="text-sm font-medium text-success-700">Available for freelance</span>
      </div>

      <!-- Main Heading -->
      <h1 
        id="hero-heading"
        class="heading-display mb-4 md:mb-6 opacity-0 animate-fade-in-up animation-delay-100"
        style="animation-fill-mode: forwards;"
      >
        Hi, I'm <span class="text-accent-600">Roshit</span>
      </h1>

      <!-- Role -->
      <p 
        class="heading-md text-primary-600 mb-4 md:mb-6 opacity-0 animate-fade-in-up animation-delay-200"
        style="animation-fill-mode: forwards;"
      >
        Full Stack Developer
      </p>

      <!-- Description -->
      <p 
        class="body-lg max-w-xl mx-auto mb-8 md:mb-10 opacity-0 animate-fade-in-up animation-delay-300"
        style="animation-fill-mode: forwards;"
      >
        I build modern web applications with React, Node.js, and cloud technologies.
        Passionate about creating elegant solutions to complex problems.
      </p>

      <!-- CTA Buttons -->
      <div 
        class="flex flex-col sm:flex-row gap-3 justify-center mb-12 md:mb-16 opacity-0 animate-fade-in-up animation-delay-400"
        style="animation-fill-mode: forwards;"
      >
        <a href="#projects" class="btn-primary group">
          View Projects
          <svg 
            class="w-4 h-4 transition-transform duration-200 group-hover:translate-y-0.5" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </a>

        <a href="#contact" class="btn-secondary">
          Contact Me
        </a>
      </div>

      <!-- Social Links -->
      <div 
        class="flex justify-center gap-3 opacity-0 animate-fade-in animation-delay-500"
        style="animation-fill-mode: forwards;"
        aria-label="Social media links"
      >
        <a 
          href="https://github.com/roshitx" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="p-3 text-primary-500 hover:text-primary-900 hover:bg-primary-100 
                 rounded-xl transition-all duration-200"
          aria-label="GitHub Profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
          </svg>
        </a>

        <a 
          href="https://linkedin.com/in/roshit" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="p-3 text-primary-500 hover:text-primary-900 hover:bg-primary-100 
                 rounded-xl transition-all duration-200"
          aria-label="LinkedIn Profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
          </svg>
        </a>

        <a 
          href="mailto:aulia.rasyid@arita.co.id" 
          class="p-3 text-primary-500 hover:text-primary-900 hover:bg-primary-100 
                 rounded-xl transition-all duration-200"
          aria-label="Send Email"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <a 
    href="#about" 
    class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center 
           gap-2 text-primary-400 hover:text-accent-600 transition-colors duration-200 group"
    aria-label="Scroll to about section"
  >
    <span class="text-xs font-medium">Scroll</span>
    <svg 
      class="w-5 h-5 animate-bounce-subtle" 
      fill="none" 
      stroke="currentColor" 
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        stroke-width="2" 
        d="M19 14l-7 7m0 0l-7-7m7 7V3"
      ></path>
    </svg>
  </a>
</section>
