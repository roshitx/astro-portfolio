---

<section id="contact" class="section-padding bg-primary-50" aria-labelledby="contact-heading">
  <div class="container-custom">
    <div class="max-w-5xl mx-auto">
      
      <!-- Section Header -->
      <div class="text-center mb-10 md:mb-14">
        <span class="text-label text-accent-600 mb-3 block">Contact</span>

        <h2 id="contact-heading" class="heading-lg mb-4">
          Let's work <span class="text-accent-600">together</span>
        </h2>

        <p class="body-lg max-w-xl mx-auto">
          Have a project in mind? Let's discuss how I can help you bring it to life.
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-8 lg:gap-12">
        
        <!-- Contact Info -->
        <div class="md:col-span-2 space-y-6">
          <div class="space-y-5">
            {contactInfo.map((info) => (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent-50 rounded-xl flex items-center justify-center flex-shrink-0 border border-accent-100">
                  <svg 
                    class="w-5 h-5 text-accent-600" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d={info.icon}
                    ></path>
                  </svg>
                </div>

                <div>
                  <h3 class="font-heading font-semibold text-sm mb-0.5">{info.title}</h3>
                  {info.href ? (
                    <a 
                      href={info.href} 
                      class="text-primary-600 hover:text-accent-600 transition-colors duration-200"
                    >
                      {info.value}
                    </a>
                  ) : (
                    <p class="text-primary-600">{info.value}</p>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- Social Links -->
          <div class="pt-6 border-t border-primary-200">
            <h3 class="font-heading font-semibold text-sm mb-4">Connect with me</h3>
            <div class="flex gap-3">
              {socialLinks.map((social) => (
                <a 
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-11 h-11 bg-white border border-primary-200 rounded-xl 
                         flex items-center justify-center text-primary-500
                         hover:text-accent-600 hover:border-accent-200 hover:shadow-soft
                         transition-all duration-200"
                  aria-label={`${social.name} Profile`}
                >
                  <svg 
                    class="w-5 h-5" 
                    fill="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d={social.icon}></path>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <form 
          class="md:col-span-3 card card-padding space-y-5"
          aria-label="Contact form"
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="label">Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="Your name"
                class="input"
                required
                autocomplete="name"
              />
            </div>

            <div>
              <label for="email" class="label">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="your@email.com"
                class="input"
                required
                autocomplete="email"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="label">Subject</label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              placeholder="What's this about?"
              class="input"
              required
            />
          </div>

          <div>
            <label for="message" class="label">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              placeholder="Tell me about your project..."
              class="textarea"
              required
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full sm:w-auto">
            Send Message
            <svg 
              class="w-4 h-4" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                stroke-width="2" 
                d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"
              ></path>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
