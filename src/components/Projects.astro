---
// Projects Section Component
const projects = [
  {
    title: 'Water Level Monitoring',
    description: 'Mobile app for real-time water level monitoring with React Native, WebSocket integration, and push notifications for critical alerts.',
    tags: ['React Native', 'TypeScript', 'WebSocket', 'Node.js'],
    image: '/images/project-1.jpg',
    link: '#',
    github: '#',
    featured: true,
  },
  {
    title: 'HRIS System',
    description: 'Human Resource Information System built with Laravel, featuring payroll management, attendance tracking, and employee self-service portal.',
    tags: ['Laravel', 'PHP', 'PostgreSQL', 'Bootstrap'],
    image: '/images/project-2.jpg',
    link: '#',
    github: '#',
    featured: false,
  },
  {
    title: 'AIS Nelayan',
    description: 'Vessel tracking system for fishermen using AIS data, with real-time map visualization and zone management capabilities.',
    tags: ['Next.js', 'Mapbox', 'Redis', 'Docker'],
    image: '/images/project-3.jpg',
    link: '#',
    github: '#',
    featured: true,
  },
  {
    title: 'FreshRSS Pipeline',
    description: 'Automated RSS feed aggregator with AI-powered summaries, integrated with Telegram notifications for content delivery.',
    tags: ['Python', 'ChromaDB', 'Docker', 'OpenAI'],
    image: '/images/project-4.jpg',
    link: '#',
    github: '#',
    featured: false,
  },
];
---

<section id="projects" class="section-padding bg-primary-50" aria-labelledby="projects-heading">
  <div class="container-custom">
    
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="text-label text-accent-600 mb-3 block">Portfolio</span>

      <h2 id="projects-heading" class="heading-lg mb-4">
        Featured <span class="text-accent-600">Projects</span>
      </h2>

      <p class="body-lg max-w-2xl mx-auto">
        Here are some of my recent projects that showcase my skills in full-stack development.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      {projects.map((project, index) => (
        <article 
          class={`group relative bg-white rounded-2xl border border-primary-100 overflow-hidden
                  transition-all duration-300 hover:shadow-elevated hover:border-primary-200
                  ${project.featured ? 'md:col-span-2 lg:col-span-1' : ''}`}
        >
          <!-- Image Container -->
          <div class="relative aspect-project bg-primary-100 overflow-hidden">
            <!-- Placeholder Pattern -->
            <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-primary-100 to-primary-50">
              <svg 
                class="w-16 h-16 md:w-20 md:h-20 text-primary-300" 
                fill="none" 
                stroke="currentColor" 
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path 
                  stroke-linecap="round" 
                  stroke-linejoin="round" 
                  stroke-width="1" 
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
            </div>

            <!-- Hover Overlay -->
            <div class="absolute inset-0 bg-primary-900/80 opacity-0 group-hover:opacity-100 
                        transition-opacity duration-300 flex items-center justify-center gap-3">
              <a 
                href={project.link} 
                class="px-4 py-2 bg-white text-primary-900 rounded-lg text-sm font-semibold
                       transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
                       transition-all duration-300 delay-75 hover:bg-primary-50"
              >
                View Demo
              </a>

              <a 
                href={project.github} 
                class="px-4 py-2 border border-white text-white rounded-lg text-sm font-semibold
                       transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
                       transition-all duration-300 delay-150 hover:bg-white/10"
              >
                GitHub
              </a>
            </div>

            <!-- Featured Badge -->
            {project.featured && (
              <div class="absolute top-4 left-4">
                <span class="tag-accent">
                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                  Featured
                </span>
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="p-5 md:p-6">
            <h3 class="text-lg md:text-xl font-heading font-bold mb-2 
                       group-hover:text-accent-600 transition-colors duration-200">
              <a href={project.link} class="focus:outline-none">
                <span class="absolute inset-0" aria-hidden="true"></span>
                {project.title}
              </a>
            </h3>

            <p class="body-sm mb-4 line-clamp-2">{project.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="tag">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- View All Button -->
    <div class="text-center mt-12">
      <a href="/projects" class="btn-secondary group">
        View All Projects
        <svg 
          class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>
