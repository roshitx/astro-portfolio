---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const navLinks = [
  { href: isHome ? '#about' : '/#about', label: 'About' },
  { href: isHome ? '#projects' : '/#projects', label: 'Projects' },
  { href: isHome ? '#blog' : '/#blog', label: 'Blog' },
  { href: '/uses', label: 'Uses' },
  { href: isHome ? '#contact' : '/#contact', label: 'Contact' },
];
---

<nav 
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  id="navbar"
  aria-label="Main navigation"
>
  <div class="absolute inset-0 bg-white/80 backdrop-blur-xl border-b border-primary-100"></div>
  
  <div class="container-custom relative">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a 
        href="/" 
        class="font-heading text-xl md:text-2xl font-bold text-primary-900 
               hover:text-accent-600 transition-colors duration-200"
        aria-label="Roshit - Home"
      >
        Roshit
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1" role="menubar">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link px-4 py-2"
            role="menuitem"
          >
            {link.label}
          </a>
        ))}

        <!-- Command palette trigger -->
        <button
          type="button"
          data-open-command-palette
          class="ml-3 inline-flex items-center gap-2 px-3 py-2 rounded-lg
                 bg-primary-50 hover:bg-primary-100 border border-primary-200
                 text-primary-500 hover:text-primary-700
                 transition-all duration-200 focus-visible:ring-2 focus-visible:ring-accent-500"
          aria-label="Open search command palette"
          title="Search (⌘K)"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 110-16 8 8 0 010 16z"></path>
          </svg>
          <span class="text-sm font-medium">Search</span>
          <kbd class="inline-flex items-center gap-0.5 px-1.5 py-0.5 font-mono text-[10px] font-semibold text-primary-500 bg-white rounded border border-primary-200">
            <span>⌘</span><span>K</span>
          </kbd>
        </button>
      </div>

      <!-- Mobile search trigger -->
      <button
        type="button"
        data-open-command-palette
        class="md:hidden ml-auto mr-1 p-2 text-primary-600 hover:text-primary-900
               rounded-lg hover:bg-primary-100 transition-all duration-200"
        aria-label="Open search"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 110-16 8 8 0 010 16z"></path>
        </svg>
      </button>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="md:hidden relative z-10 p-2 -mr-2 text-primary-600 hover:text-primary-900 
               rounded-lg hover:bg-primary-100 transition-all duration-200"
        id="mobile-menu-btn"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg 
          class="w-6 h-6 transition-transform duration-200" 
          id="menu-icon"
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M4 6h16M4 12h16M4 18h16"
          ></path>
        </svg>
        <svg 
          class="w-6 h-6 hidden" 
          id="close-icon"
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M6 18L18 6M6 6l12 12"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div 
      class="md:hidden absolute top-full left-0 right-0 bg-white border-b border-primary-100
             shadow-elevated transform origin-top transition-all duration-300 opacity-0 invisible
             -translate-y-2"
      id="mobile-menu"
      role="menu"
      aria-label="Mobile navigation"
    >
      <div class="container-custom py-4 space-y-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 text-base font-medium text-primary-700 
                   rounded-lg hover:bg-primary-50 hover:text-accent-600
                   transition-all duration-200"
            role="menuitem"
          >
            {link.label}
          </a>
        ))}
        <div class="pt-2 mt-2 border-t border-primary-100">
          <a 
            href="/blog" 
            class="block px-4 py-3 text-base font-semibold text-accent-600 
                   bg-accent-50 rounded-lg hover:bg-accent-100
                   transition-all duration-200"
            role="menuitem"
          >
            View All Posts
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  (function() {
    const navbar = document.getElementById('navbar');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    
    let isMenuOpen = false;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;
      
      // Update ARIA attributes
      mobileMenuBtn?.setAttribute('aria-expanded', String(isMenuOpen));
      
      // Toggle menu visibility with animation
      if (isMenuOpen) {
        mobileMenu?.classList.remove('opacity-0', 'invisible', '-translate-y-2');
        mobileMenu?.classList.add('opacity-100', 'visible', 'translate-y-0');
        menuIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu?.classList.add('opacity-0', 'invisible', '-translate-y-2');
        mobileMenu?.classList.remove('opacity-100', 'visible', 'translate-y-0');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        document.body.style.overflow = '';
      }
    }

    function closeMenu() {
      if (isMenuOpen) {
        toggleMenu();
      }
    }

    // Toggle menu on button click
    mobileMenuBtn?.addEventListener('click', toggleMenu);

    // Close menu on link click
    mobileMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Add shadow on scroll
    let lastScrollY = window.scrollY;
    
    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      
      if (currentScrollY > 10) {
        navbar?.querySelector('.absolute')?.classList.add('shadow-sm');
      } else {
        navbar?.querySelector('.absolute')?.classList.remove('shadow-sm');
      }
      
      lastScrollY = currentScrollY;
    }, { passive: true });

    // Close menu on resize to desktop
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        closeMenu();
        mobileMenuBtn?.focus();
      }
    });

    // Handle hash links for smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href && href !== '#') {
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            const navHeight = navbar?.offsetHeight || 80;
            const targetPosition = target.getBoundingClientRect().top + window.scrollY - navHeight;
            window.scrollTo({
              top: targetPosition,
              behavior: 'smooth'
            });
          }
        }
      });
    });
  })();
</script>

<style>
  /* Offset for fixed navbar */
  :global(section[id]) {
    scroll-margin-top: 5rem;
  }
  
  @media (min-width: 768px) {
    :global(section[id]) {
      scroll-margin-top: 6rem;
    }
  }
</style>
