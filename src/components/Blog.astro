---
import { getCollection } from 'astro:content';

// Get latest 3 blog posts
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<section id="blog" class="section-padding bg-white" aria-labelledby="blog-heading">
  <div class="container-custom">
    
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="text-label text-accent-600 mb-3 block">Blog</span>

      <h2 id="blog-heading" class="heading-lg mb-4">
        Latest <span class="text-accent-600">Articles</span>
      </h2>

      <p class="body-lg max-w-2xl mx-auto">
        Thoughts, tutorials, and insights about web development and technology.
      </p>
    </div>

    <!-- Blog Grid -->
    {posts.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {posts.map((post, index) => (
          <article class="group card card-interactive">
            <!-- Meta -->
            <div class="flex items-center gap-3 mb-4">
              <span class="tag-accent">
                {post.data.category}
              </span>
              
              {post.data.readTime && (
                <>
                  <span class="text-primary-300">•</span>
                  <span class="text-sm text-primary-500">{post.data.readTime}</span>
                </>
              )}
            </div>

            <!-- Title -->
            <h3 class="text-lg md:text-xl font-heading font-bold mb-3 
                       group-hover:text-accent-600 transition-colors duration-200">
              <a href={`/blog/${post.slug}`} class="focus:outline-none">
                <span class="absolute inset-0" aria-hidden="true"></span>
                {post.data.title}
              </a>
            </h3>

            <!-- Description -->
            <p class="body-sm mb-6 line-clamp-2">
              {post.data.description}
            </p>

            <!-- Footer -->
            <div class="flex items-center justify-between pt-4 border-t border-primary-100">
              <time 
                class="text-sm text-primary-500" 
                datetime={post.data.date.toISOString()}
              >
                {formatDate(post.data.date)}
              </time>

              <a 
                href={`/blog/${post.slug}`} 
                class="text-sm font-semibold text-accent-600 hover:text-accent-700 
                       inline-flex items-center gap-1 transition-colors duration-200 
                       relative z-10"
              >
                Read more
                <svg 
                  class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path 
                    stroke-linecap="round" 
                    stroke-linejoin="round" 
                    stroke-width="2" 
                    d="M9 5l7 7-7 7"
                  ></path>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <!-- Empty State -->
      <div class="text-center py-16 bg-primary-50 rounded-2xl border border-primary-100">
        <svg 
          class="w-16 h-16 text-primary-300 mx-auto mb-4" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="1.5" 
            d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
          ></path>
        </svg>
        <h3 class="heading-sm mb-2">No articles yet</h3>
        <p class="body-md">Check back soon for new content!</p>
      </div>
    )}

    <!-- View All Button -->
    <div class="text-center mt-12">
      <a href="/blog" class="btn-secondary group">
        View All Articles
        <svg 
          class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>
