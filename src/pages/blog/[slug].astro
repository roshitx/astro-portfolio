---
import Layout from '../../layouts/Layout.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { getCollection } from 'astro:content';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// Get the current post from props
const { post } = Astro.props;

// Get all posts for prev/next navigation
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost =
  currentIndex < sortedPosts.length - 1
    ? sortedPosts[currentIndex + 1]
    : null;

const { Content } = await post.render();
---

<Layout
  title={`${post.data.title} - Roshit`}
  description={post.data.description}
  type="article"
>
  <main class="pt-24 pb-20">
    <article class="container-custom">
      <!-- Back to blog link -->
      <a
        href="/blog"
        class="inline-flex items-center text-accent-600 hover:text-accent-700 mb-8 font-medium transition-colors duration-200"
      >
        <svg
          class="w-5 h-5 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"
          ></path>
        </svg>
        Back to Blog
      </a>

      <!-- Post Header -->
      <header class="max-w-3xl mx-auto mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="tag-accent">
            {post.data.category}
          </span>
          {post.data.readTime && (
            <>
              <span class="text-primary-300">•</span>
              <span class="text-sm text-primary-500">{post.data.readTime}</span>
            </>
          )}
        </div>

        <h1 class="heading-lg mb-4">{post.data.title}</h1>

        <p class="body-lg mb-6">{post.data.description}</p>

        <div class="flex items-center gap-4 text-sm text-primary-500">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-accent-600 rounded-full flex items-center justify-center text-white font-semibold">
              {post.data.author.charAt(0)}
            </div>
            <span class="font-medium text-primary-700">{post.data.author}</span>
          </div>
          <span class="text-primary-300">•</span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', {
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            })}
          </time>
        </div>
      </header>

      <!-- Post Content -->
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </div>

      <!-- Tags -->
      <div class="max-w-3xl mx-auto mt-12 pt-8 border-t border-primary-100">
        <h3 class="heading-sm mb-4">Tags</h3>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={`/blog?tag=${tag}`}
              class="tag hover:bg-primary-200 transition-colors duration-200"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="max-w-3xl mx-auto mt-12 pt-8 border-t border-primary-100">
        <div class="grid md:grid-cols-2 gap-4">
          {prevPost && (
            <a
              href={`/blog/${prevPost.slug}`}
              class="group p-5 sm:p-6 bg-primary-50 rounded-xl hover:bg-primary-100 transition-colors duration-200"
            >
              <div class="text-sm text-primary-500 mb-2">← Previous</div>
              <h3 class="text-base sm:text-lg font-semibold group-hover:text-accent-600 transition-colors duration-200 line-clamp-2">
                {prevPost.data.title}
              </h3>
            </a>
          )}

          {nextPost && (
            <a
              href={`/blog/${nextPost.slug}`}
              class="group p-5 sm:p-6 bg-primary-50 rounded-xl hover:bg-primary-100 transition-colors duration-200 md:ml-auto md:text-right"
            >
              <div class="text-sm text-primary-500 mb-2">Next →</div>
              <h3 class="text-base sm:text-lg font-semibold group-hover:text-accent-600 transition-colors duration-200 line-clamp-2">
                {nextPost.data.title}
              </h3>
            </a>
          )}
        </div>
      </div>
    </article>
    <ScrollToTop />
  </main>
</Layout>

<style>
  /* Prose styling for blog content */
  .prose {
    @apply text-primary-700;
  }

  .prose h2 {
    @apply font-heading text-2xl sm:text-3xl font-bold mt-10 mb-4 leading-tight;
  }

  .prose h3 {
    @apply font-heading text-xl sm:text-2xl font-semibold mt-8 mb-3 leading-tight;
  }

  .prose p {
    @apply mb-6 leading-relaxed;
  }

  .prose ul,
  .prose ol {
    @apply mb-6 pl-6;
  }

  .prose li {
    @apply mb-2;
  }

  .prose li > p {
    @apply mb-2;
  }

  .prose code {
    @apply text-sm font-mono font-medium px-1.5 py-0.5 bg-primary-100 text-primary-800 rounded;
  }

  .prose pre {
    @apply my-6 p-4 sm:p-5 bg-primary-900 text-primary-100 rounded-xl overflow-x-auto;
  }

  .prose pre code {
    @apply bg-transparent text-inherit p-0 font-normal;
  }

  .prose a {
    @apply text-accent-600 font-medium underline-offset-4 hover:underline transition-colors duration-200;
  }

  .prose blockquote {
    @apply my-6 pl-4 border-l-4 border-accent-500 italic text-primary-600;
  }

  .prose hr {
    @apply my-8 border-primary-200;
  }

  .prose img {
    @apply rounded-xl my-6;
  }

  .prose table {
    @apply w-full my-6 border-collapse;
  }

  .prose th {
    @apply px-4 py-3 bg-primary-100 text-left font-semibold text-primary-900 border-b border-primary-200;
  }

  .prose td {
    @apply px-4 py-3 border-b border-primary-100;
  }

  .prose strong {
    @apply font-semibold text-primary-900;
  }
</style>
