---
import Layout from '../../layouts/Layout.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { getCollection } from 'astro:content';

// Get all blog posts sorted by date
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Get unique categories
const categories = [...new Set(allPosts.map((post) => post.data.category))];

// Get unique tags
const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

// Current filter (from URL query params)
const categoryFilter = new URL(Astro.url).searchParams.get('category');
const tagFilter = new URL(Astro.url).searchParams.get('tag');

// Filter posts
let filteredPosts = allPosts;
if (categoryFilter) {
  filteredPosts = filteredPosts.filter(
    (post) => post.data.category === categoryFilter
  );
}
if (tagFilter) {
  filteredPosts = filteredPosts.filter((post) =>
    post.data.tags.includes(tagFilter)
  );
}
---

<Layout 
  title="Blog - Roshit" 
  description="Thoughts, tutorials, and insights about web development and technology."
>
  <main class="pt-24 pb-20">
    <div class="container-custom">
      <!-- Header -->
      <div class="text-center mb-12 md:mb-16">
        <span class="text-label text-accent-600 mb-3 block">Blog</span>

        <h1 class="heading-lg mb-4">
          Latest <span class="text-accent-600">Articles</span>
        </h1>

        <p class="body-lg max-w-2xl mx-auto">
          Thoughts, tutorials, and insights about web development and technology.
        </p>
      </div>

      <!-- Filters -->
      <div class="mb-12 space-y-6">
        <!-- Category Filter -->
        <div class="flex flex-wrap gap-2 justify-center">
          <a
            href="/blog"
            class={`px-4 py-2 rounded-full font-medium text-sm transition-all duration-200 ${
              !categoryFilter
                ? 'bg-accent-600 text-white shadow-elevated'
                : 'bg-primary-100 text-primary-700 hover:bg-primary-200'
            }`}
          >
            All
          </a>
          {categories.map((category) => (
            <a
              href={`/blog?category=${category}`}
              class={`px-4 py-2 rounded-full font-medium text-sm transition-all duration-200 ${
                categoryFilter === category
                  ? 'bg-accent-600 text-white shadow-elevated'
                  : 'bg-primary-100 text-primary-700 hover:bg-primary-200'
              }`}
            >
              {category}
            </a>
          ))}
        </div>

        <!-- Tag Filter (if category is selected) -->
        {categoryFilter && (
          <div class="flex flex-wrap gap-2 justify-center items-center">
            <span class="text-sm text-primary-500">Filter by tag:</span>
            <a
              href="/blog"
              class="text-sm text-accent-600 hover:text-accent-700 font-medium transition-colors"
            >
              Clear all
            </a>
            {tags
              .filter((tag) =>
                allPosts
                  .filter((p) => p.data.category === categoryFilter)
                  .some((p) => p.data.tags.includes(tag))
              )
              .map((tag) => (
                <a
                  href={`/blog?category=${categoryFilter}&tag=${tag}`}
                  class={`px-3 py-1 text-sm rounded-full transition-all duration-200 ${
                    tagFilter === tag
                      ? 'bg-accent-100 text-accent-700'
                      : 'bg-primary-100 text-primary-600 hover:bg-primary-200'
                  }`}
                >
                  {tag}
                </a>
              ))}
          </div>
        )}
      </div>

      <!-- Posts Grid -->
      {filteredPosts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {filteredPosts.map((post) => (
            <article
              class="group card card-interactive p-5 sm:p-6"
            >
              <!-- Meta -->
              <div class="flex items-center gap-3 mb-4">
                <span class="tag-accent">
                  {post.data.category}
                </span>
                {post.data.readTime && (
                  <>
                    <span class="text-primary-300">•</span>
                    <span class="text-sm text-primary-500">{post.data.readTime}</span>
                  </>
                )}
              </div>

              <!-- Title -->
              <h2 class="text-lg sm:text-xl font-heading font-bold mb-3 
                         group-hover:text-accent-600 transition-colors duration-200">
                <a href={`/blog/${post.slug}`} class="focus:outline-none">
                  <span class="absolute inset-0" aria-hidden="true"></span>
                  {post.data.title}
                </a>
              </h2>

              <!-- Description -->
              <p class="body-sm mb-6 line-clamp-2">
                {post.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <a
                    href={`/blog?tag=${tag}`}
                    class="text-xs px-2 py-1 bg-primary-100 text-primary-600 rounded 
                           hover:bg-primary-200 transition-colors duration-200 relative z-10"
                  >
                    #{tag}
                  </a>
                ))}
              </div>

              <!-- Footer -->
              <div class="flex items-center justify-between pt-4 border-t border-primary-100">
                <time class="text-sm text-primary-500" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric',
                  })}
                </time>

                <a
                  href={`/blog/${post.slug}`}
                  class="text-sm font-semibold text-accent-600 hover:text-accent-700 
                         inline-flex items-center gap-1 transition-colors duration-200 relative z-10"
                >
                  Read more
                  <svg
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    ></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-primary-50 rounded-2xl border border-primary-100">
          <svg
            class="w-16 h-16 text-primary-300 mx-auto mb-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
            ></path>
          </svg>
          <h3 class="heading-sm mb-2">No articles found</h3>
          <p class="body-md">Try adjusting your filters or check back later!</p>
          <a
            href="/blog"
            class="mt-4 inline-flex items-center text-accent-600 font-medium hover:text-accent-700"
          >
            View all posts
            <svg
              class="w-4 h-4 ml-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </a>
        </div>
      )}
    </div>
    <ScrollToTop />
  </main>
</Layout>
