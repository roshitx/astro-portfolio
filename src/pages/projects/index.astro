---
import Layout from '../../layouts/Layout.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';

const allProjects = [
  {
    title: 'Water Level Monitoring',
    description: 'Mobile app for real-time water level monitoring with React Native, WebSocket integration, and push notifications.',
    longDescription: 'A comprehensive water level monitoring system built with React Native. Features include real-time WebSocket data streaming, push notifications for critical alerts, historical data visualization, and user management. The app connects to IoT sensors deployed across various water bodies, providing instant updates to stakeholders.',
    tags: ['React Native', 'TypeScript', 'WebSocket', 'Node.js'],
    image: '/images/project-1.jpg',
    link: '#',
    github: '#',
    features: [
      'Real-time WebSocket data streaming',
      'Push notifications for alerts',
      'Historical data visualization',
      'User authentication and roles',
      'Offline data caching',
    ],
  },
  {
    title: 'HRIS System',
    description: 'Human Resource Information System built with Laravel, featuring payroll management, attendance tracking, and employee self-service.',
    longDescription: 'A full-featured HR management system built with Laravel. Includes comprehensive payroll management with tax calculations, attendance tracking with biometric integration, leave management, performance reviews, and employee self-service portal. The system serves multiple departments and handles complex organizational structures.',
    tags: ['Laravel', 'PHP', 'PostgreSQL', 'Bootstrap'],
    image: '/images/project-2.jpg',
    link: '#',
    github: '#',
    features: [
      'Payroll management with tax calculations',
      'Attendance tracking with biometric integration',
      'Leave management system',
      'Employee self-service portal',
      'Performance review module',
    ],
  },
  {
    title: 'AIS Nelayan',
    description: 'Vessel tracking system for fishermen using AIS data, with real-time map visualization and zone management.',
    longDescription: 'An innovative vessel tracking system for Indonesian fishermen. Processes AIS (Automatic Identification System) data to track vessels in real-time. Features include interactive map visualization, geofencing for fishing zones, alert system for unauthorized entries, and vessel fleet management.',
    tags: ['Next.js', 'Mapbox', 'Redis', 'Docker'],
    image: '/images/project-3.jpg',
    link: '#',
    github: '#',
    features: [
      'Real-time vessel tracking',
      'Interactive map with Mapbox',
      'Geofencing for fishing zones',
      'Alert system for violations',
      'Vessel fleet management',
    ],
  },
  {
    title: 'FreshRSS Pipeline',
    description: 'Automated RSS feed aggregator with AI-powered summaries, integrated with Telegram notifications.',
    longDescription: 'A personalized RSS aggregation system with AI enhancement. Automatically fetches articles from multiple sources, generates AI-powered summaries, and delivers relevant content via Telegram. Built with Python, ChromaDB for vector search, and Docker for deployment.',
    tags: ['Python', 'ChromaDB', 'Docker', 'OpenAI'],
    image: '/images/project-4.jpg',
    link: '#',
    github: '#',
    features: [
      'Multi-source RSS aggregation',
      'AI-powered article summaries',
      'Telegram notification integration',
      'Vector search with ChromaDB',
      'Dockerized deployment',
    ],
  },
];
---

<Layout
  title="Projects - Roshit"
  description="Featured projects showcasing full-stack development skills"
>
  <main class="pt-24 pb-20">
    <div class="container-custom">
      <!-- Header -->
      <div class="text-center mb-16">
        <span class="text-primary-600 font-medium mb-2 block">Portfolio</span>

        <h1 class="text-4xl md:text-6xl font-bold mb-4">
          Featured <span class="gradient-text">Projects</span>
        </h1>

        <p class="text-gray-600 text-lg max-w-2xl mx-auto">
          Here are some of my recent projects that showcase my skills in full-stack
          development.
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="space-y-16">
        {allProjects.map((project, index) => (
          <article
            class={`grid md:grid-cols-2 gap-8 items-center ${
              index % 2 === 1 ? 'md:flex-row-reverse' : ''
            }`}
          >
            <!-- Image -->
            <div class="relative overflow-hidden rounded-2xl aspect-video bg-gradient-to-br from-primary-100 to-purple-100">
              <div class="absolute inset-0 flex items-center justify-center text-primary-300">
                <svg
                  class="w-24 h-24"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
            </div>

            <!-- Content -->
            <div>
              <h2 class="text-3xl font-bold mb-4">{project.title}</h2>

              <p class="text-gray-600 mb-6">{project.longDescription}</p>

              <!-- Features -->
              <div class="mb-6">
                <h3 class="font-semibold mb-3">Key Features:</h3>
                <ul class="space-y-2">
                  {project.features.map((feature) => (
                    <li class="flex items-start gap-2 text-gray-600">
                      <svg
                        class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        ></path>
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-6">
                {project.tags.map((tag) => (
                  <span
                    key={tag}
                    class="px-3 py-1 bg-primary-50 text-primary-700 text-sm rounded-full font-medium"
                  >
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex gap-4">
                <a
                  href={project.link}
                  class="btn-primary inline-flex items-center"
                >
                  View Demo
                  <svg
                    class="w-5 h-5 ml-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    ></path>
                  </svg>
                </a>

                <a
                  href={project.github}
                  class="btn-secondary inline-flex items-center"
                >
                  <svg
                    class="w-5 h-5 mr-2"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                  </svg>
                  GitHub
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-20 text-center">
        <h2 class="text-3xl font-bold mb-4">
          Have a project in mind?
        </h2>

        <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
          I'm always open to discussing new projects, creative ideas, or opportunities
          to be part of your vision.
        </p>

        <a href="#contact" class="btn-primary inline-flex items-center">
          Let's Talk
          <svg
            class="w-5 h-5 ml-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            ></path>
          </svg>
        </a>
      </div>
    </div>
    <ScrollToTop />
  </main>
</Layout>
