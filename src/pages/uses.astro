                      <span class="min-w-0 flex-1">
                        <span class="flex items-center gap-1.5">
                          <span class="font-heading font-semibold text-primary-900 group-hover:text-accent-600 transition-colors duration-200">
                            {item.name}
                          </span>
                          {item.link && (
                            <svg
                              class="w-3.5 h-3.5 text-primary-400 group-hover:text-accent-500 transition-colors duration-200"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                            </svg>
                          )}
                        </span>
                        <span class="body-sm mt-1 block">{item.description}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>

      <!-- Closing note -->
      <aside class="mt-16 md:mt-20 max-w-2xl mx-auto text-center p-8 rounded-2xl bg-white border border-primary-100 shadow-soft">
        <h2 class="heading-sm mb-3">Have a tool I should try?</h2>
        <p class="body-md mb-5">
          I'm always curious about new gear and workflow improvements. If you have a recommendation,
          I'd love to hear it.
        </p>
        <a href="/#contact" class="btn-primary">
          Send me a tip
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/>
          </svg>
        </a>
      </aside>
    </div>
  </main>

  <Footer />
  <ScrollToTop />
</Layout>
